# ============================================================
# Portfolio Photographe — Variables d'environnement Backend
# Copiez ce fichier en .env.local et remplissez les valeurs
# NE JAMAIS committer le fichier .env.local dans Git !
# ============================================================

# ── Base de données ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=portfolio_db
DB_USER=portfolio_user
DB_PASSWORD=change_me_in_production

# ── JWT ──────────────────────────────────────────────────────
# Générez une clé aléatoire de min. 32 caractères
JWT_SECRET=change_this_secret_key_minimum_32_characters_required
JWT_EXPIRATION=86400000

# ── Cloudinary (https://cloudinary.com/console) ──────────────
# Créez un compte gratuit sur cloudinary.com
# Copiez vos identifiants depuis : Dashboard > API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4200

# ── Email (optionnel) ─────────────────────────────────────────
ADMIN_EMAIL=admin@votredomaine.com
MAIL_FROM=noreply@votredomaine.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre@gmail.com
SMTP_PASSWORD=votre_app_password_gmail
